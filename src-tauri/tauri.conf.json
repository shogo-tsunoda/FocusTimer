{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FocusTimer",
  "version": "0.1.0",
  "identifier": "com.focustimer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FocusTimer",
        "width": 320,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": false,
        "visible": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
